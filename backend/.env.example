# Copiar como .env para desarrollo local
# En producción, estas variables se configuran en Render dashboard

# PostgreSQL — Neon connection string
# Obtener en: https://console.neon.tech → tu proyecto → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/surmaderas?sslmode=require

# Entorno
ENVIRONMENT=production

# URL del frontend (para CORS)
# Producción: https://surmaderas-erp.vercel.app
FRONTEND_URL=https://tu-app.vercel.app

# Clave secreta para JWT (generada automáticamente en Render)
SECRET_KEY=cambia-esto-por-una-clave-segura
